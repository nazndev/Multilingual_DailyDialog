# Env and secrets (never commit tokens)
.env
.env.local
.env.*.local
*.pem

# Python
.venv/
.venv*/
venv/
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/

# Generated data and model outputs
# By default ignore all generated artifacts, but allow committing a few
# small, reproducible JSONL outputs that are needed for Colab runs.
!data/
data/*
!data/translated_api_1000_bn/
!data/translated_api_1000_bn/*.jsonl
!data/sft/
data/sft/*
!data/sft/sampled_1000_bn/
!data/sft/sampled_1000_bn/*.jsonl

cache/
outputs/
reports/
*.log
logs/

# IDE / editor / OS
.idea/
.vscode/
.cursor/
*.swp
*.swo
.DS_Store

# Temp / non-project
src/tt
agent-transcripts/
*.tmp
