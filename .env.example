# Copy to .env (DO NOT COMMIT .env)
# Languages
SOURCE_LANG=en
TARGET_LANGS=bn

# Base directories (override defaults)
DATA_DIR=./data
CACHE_DIR=./cache
OUTPUTS_DIR=./outputs
REPORTS_DIR=./reports

# Models (optional overrides)
BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
TRANSLATION_MODEL=facebook/nllb-200-distilled-600M

# Runtime
DEVICE=auto

# Optional: Hugging Face (for dataset download only; never commit real tokens)
# HF_TOKEN=

# Optional: LLM translation (step 3). Set TRANSLATION_BACKEND=api and OPENAI_API_KEY=sk-...
# TRANSLATION_BACKEND=api
# OPENAI_API_KEY=
